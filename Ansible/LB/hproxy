server {
    listen 80;
    server_name haproxy.jnrpro.solutions;  # add your domain name

    # Instantly redirect any plain HTTP traffic to secure HTTPS
    return 301 https://$host$request_uri;
}
server {
    listen 443 ssl;
    server_name haproxy.jnrpro.solutions;  # add your domain name
    ssl_certificate /etc/letsencrypt/live/haproxy.jnrpro.solutions/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/haproxy.jnrpro.solutions/privkey.pem;

    location / {
        proxy_pass http://127.0.0.1:8404/stats;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}